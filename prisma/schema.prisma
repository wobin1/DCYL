generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String
  schoolName  String
  gradeLevel  String
  essayTitle  String
  content     String?
  filePath    String?
  score       Int?
  feedback    String?
  createdAt   DateTime @default(now())
  status      String   @default("PENDING")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SiteSettings {
  id              String   @id @default(cuid())
  mission         String
  vision          String
  foundingStory   String
  founderName     String
  founderTitle    String
  founderMessage  String
  founderImageUrl String?
  contactEmail    String
  contactPhone    String
  updatedAt       DateTime @updatedAt
}

model Value {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Milestone {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Program {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String
  longDescription String?
  impact          String
  imageUrl        String?
  order           Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  testimonials    Testimonial[]
}

model ImpactMetric {
  id        String   @id @default(cuid())
  label     String
  value     String
  icon      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String?
  quote     String
  imageUrl  String?
  programId String?
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  program   Program? @relation(fields: [programId], references: [id])
}

model AnnualReport {
  id            String   @id @default(cuid())
  year          String
  title         String
  fileUrl       String
  coverImageUrl String?
  createdAt     DateTime @default(now())
}

model DonationTier {
  id          String   @id @default(cuid())
  amount      Int
  currency    String   @default("NGN")
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model VolunteerRole {
  id           String   @id @default(cuid())
  title        String
  description  String
  requirements String
  active       Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String
  date            DateTime
  endDate         DateTime?
  location        String?
  imageUrl        String?
  registrationUrl String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  imageUrl  String?
  linkedIn  String?
  email     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
